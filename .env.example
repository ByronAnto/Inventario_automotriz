##############################################################
# AutoPartes Inventory - Supabase Self-Hosted Environment
#
# USO:
#   cp .env.example .env   (solo la primera vez)
#   ./setup.sh             (detecta IP y levanta todo)
#
# NOTA: Los tokens JWT de desarrollo ya coinciden con docker/kong.yml.
#       En producción, regenera JWT_SECRET + tokens y actualiza kong.yml.
##############################################################

# ── Secrets (CAMBIAR en producción) ──────────────────────────
POSTGRES_PASSWORD=AutoPartes2026Secure!
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
PG_META_CRYPTO_KEY=your-super-secret-crypto-key-at-least-32-chars!

# ── JWT Tokens (deben coincidir con docker/kong.yml) ─────────
# Generados con JWT_SECRET de arriba en https://jwt.io (HS256)
# ANON_KEY payload:         {"role":"anon","iss":"supabase","iat":1700000000,"exp":2000000000}
# SERVICE_ROLE_KEY payload: {"role":"service_role","iss":"supabase","iat":1700000000,"exp":2000000000}
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzAwMDAwMDAwLCJleHAiOjIwMDAwMDAwMDB9.6ldkvHM8WjwyHI_tKbJOgWu-VbulTx9jmeuEvNGSFkY
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3MDAwMDAwMDAsImV4cCI6MjAwMDAwMDAwMH0.mjENke8J4x_734atFXjInx76tWeHpG_5y1KaXY_3Smg

# ── Puertos ──────────────────────────────────────────────────
POSTGRES_PORT=5434
KONG_HTTP_PORT=8000
STUDIO_PORT=3100
META_PORT=8090
GOTRUE_PORT=9999
REALTIME_PORT=4000
REST_PORT=3200
STORAGE_PORT=5000
IMGPROXY_PORT=5001

# ── Frontend Web (contenedor Nginx) ──────────────────────────
WEB_PORT=3001

# ── URLs (cambiar localhost por tu IP/dominio en producción) ─
SITE_URL=http://localhost:3100
API_EXTERNAL_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000

# ── Auth (GoTrue) ────────────────────────────────────────────
GOTRUE_SITE_URL=http://localhost:3100
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_SMS_AUTOCONFIRM=true
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_ENABLE_SIGNUP=true

# ── Database ─────────────────────────────────────────────────
POSTGRES_HOST=supabase-db
POSTGRES_DB=postgres
POSTGRES_USER=postgres

# ── Studio ───────────────────────────────────────────────────
STUDIO_DEFAULT_ORGANIZATION=AutoPartes
STUDIO_DEFAULT_PROJECT=Inventario Automotriz

# ── Usuario Admin (se crea automáticamente con init-schema.sh) ─
ADMIN_EMAIL=admin@autopartes.com
ADMIN_PASSWORD=Admin2026!
ADMIN_NOMBRE=Administrador
